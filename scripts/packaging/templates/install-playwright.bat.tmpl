@echo off
REM install-playwright.bat - optional Chromium install for the Medium/Velog
REM "browser login" adapters.
REM
REM Source-controlled copy for scripts/install-playwright.bat in the built
REM package (Plan 2026-07-07-006 Unit 5). This file uses ONLY relative paths
REM (%~dp0-derived), so no build-time templating is needed -- the build
REM script copies it as-is into the output package's scripts/ directory.
REM
REM chcp 65001 guards against the non-UTF-8-console encoding crash fixed in
REM docs/plans/2026-07-03-001-fix-windows-webui-encoding-crash-plan.md.
chcp 65001 >nul

REM This file lives at <pkg_dir>\scripts\install-playwright.bat, so the
REM package root is one level up. pushd is used deliberately instead of CD's
REM /D switch: CD /D cannot make a UNC/network-share path the current
REM directory, but pushd maps it to a temporary drive letter, so this still
REM works when the package is unzipped onto e.g. \\server\share\backlink-publisher\.
set "PKG_DIR=%~dp0.."
pushd "%PKG_DIR%" || (
    echo ERROR: could not change to the package directory "%PKG_DIR%".
    pause
    exit /b 1
)
set "PKG_DIR=%CD%"

set "PYTHON_EXE=%PKG_DIR%\python-embed\python.exe"
if not exist "%PYTHON_EXE%" (
    echo ERROR: %PYTHON_EXE% was not found.
    echo This package looks incomplete or corrupted -- please re-download
    echo or re-extract the zip and try again.
    echo.
    pause
    popd
    exit /b 1
)

echo ========================================================================
echo  Backlink Publisher - Playwright ^(Chromium^) installer
echo ========================================================================
echo.
echo Only the Medium and Velog platforms use a "browser login" binding,
echo which needs the Chromium browser that Playwright manages. If you only
echo plan to use Telegraph, dev.to, or Blogger, you do NOT need to run this
echo at all.
echo.
echo This downloads Chromium (roughly 150-200 MB) into your own Windows user
echo profile cache, NOT into this package folder -- so updating or moving
echo this package to a new location later will not require re-downloading
echo the browser.
echo.
echo This may take a few minutes depending on your internet connection.
echo Please wait...
echo.

"%PYTHON_EXE%" -m playwright install chromium
set "EXITCODE=%ERRORLEVEL%"

echo.
if "%EXITCODE%"=="0" (
    echo ========================================================================
    echo  Done. Chromium is installed - Medium and Velog logins are ready.
    echo  You can trigger the login itself from the WebUI's Settings page.
    echo ========================================================================
) else (
    echo ========================================================================
    echo  Playwright install FAILED ^(exit code %EXITCODE%^).
    echo  Check your internet connection and try again. If it keeps failing,
    echo  see the troubleshooting section in README.md.
    echo ========================================================================
)
echo.
pause
popd
exit /b %EXITCODE%
