<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dex.bp-recheck</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/dex/YDEX/INPORTANT WORK/外链/backlink-publisher-69/backlink-publisher/scripts/run-recheck-periodic.sh</string>
        <string>--probe</string>
    </array>
    <!-- Weekly: Monday 04:30 local. Calendar scheduling is the in-repo
         convention (see com.dex.bp-full-pipeline.plist). The weekly sweep
         covers all due links oldest-first within the probe-batch budget;
         leftovers defer to the next run. -->
