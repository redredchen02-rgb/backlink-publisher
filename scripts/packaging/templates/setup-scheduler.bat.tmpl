@echo off
REM setup-scheduler.bat - Windows Task Scheduler helper for recurring runs.
REM
REM Source-controlled copy for scripts/setup-scheduler.bat in the built
REM package (Plan 2026-07-07-006 Unit 5). This file uses ONLY relative paths
REM (%~dp0-derived), so no build-time templating is needed -- the build
REM script copies it as-is into the output package's scripts/ directory.
REM
REM OS-level task scheduling is genuinely something the WebUI cannot do for
REM itself (it would need to reach outside its own process to register a
REM Task Scheduler entry), so unlike setup-wizard.bat this is not redundant
REM with anything else the package already provides.
REM
REM The concrete schtasks invocation below mirrors the one already
REM documented for developer checkouts in docs/windows-setup.md's scheduled-
REM task section, adjusted to call the packaged pipeline-orchestrator CLI
REM shim (scripts\cli-shims\pipeline-orchestrator.bat) instead of
REM ".venv\Scripts\python.exe -m backlink_publisher.cli.pipeline_orchestrator".
REM
REM chcp 65001 guards against the non-UTF-8-console encoding crash fixed in
REM docs/plans/2026-07-03-001-fix-windows-webui-encoding-crash-plan.md.
chcp 65001 >nul

REM This file lives at <pkg_dir>\scripts\setup-scheduler.bat, so the package
REM root is one level up. pushd (not CD /D) so this still works when the
REM package is unzipped onto a UNC / network-share path.
set "PKG_DIR=%~dp0.."
pushd "%PKG_DIR%" || (
    echo ERROR: could not change to the package directory "%PKG_DIR%".
    pause
    exit /b 1
)
set "PKG_DIR=%CD%"

set "TASK_NAME=Backlink Publisher Full Pipeline"
set "PIPELINE_BAT=%PKG_DIR%\scripts\cli-shims\pipeline-orchestrator.bat"

if not exist "%PIPELINE_BAT%" (
    echo ERROR: %PIPELINE_BAT% was not found.
    echo This package looks incomplete or corrupted -- please re-extract the
    echo zip and try again.
    echo.
    pause
    popd
    exit /b 1
)

echo ========================================================================
echo  Backlink Publisher - Scheduled Task setup
echo ========================================================================
echo.
echo Windows has no built-in equivalent of macOS/Linux cron inside this
echo package, so recurring runs (e.g. "publish once every day") go through
echo Windows' own Task Scheduler instead. Pick an option:
echo.
echo   [1] Create a daily 04:00 task automatically (schtasks), running the
echo       full pipeline: plan -^> validate -^> publish
echo   [2] Open Task Scheduler yourself so you can pick a different
echo       schedule or command
echo   [3] Just print the schtasks command so you can run/adjust it yourself
echo   [0] Cancel, do nothing
echo.
REM set /p (not `choice`) deliberately -- `choice.exe` is unreliable once
REM `chcp 65001` is active (confirmed during Unit 5 testing: it can fail to
REM read a selection at all and print "the file is either empty or does not
REM contain the valid choices", defaulting to whatever fallback branch is
REM wired up), while `set /p` reads a plain line of text and has no such
REM codepage sensitivity.
set "CHOICE="
set /p "CHOICE=Choose an option (1/2/3/0): "

if "%CHOICE%"=="1" goto :CREATE_TASK
if "%CHOICE%"=="2" goto :OPEN_GUI
if "%CHOICE%"=="3" goto :SHOW_ONLY
goto :CANCEL

:CREATE_TASK
echo.
echo Creating scheduled task "%TASK_NAME%" (daily at 04:00)...
echo Note: /RL HIGHEST may prompt for administrator permission, or fail if
echo this window itself is not running as Administrator.
schtasks /CREATE /SC DAILY /TN "%TASK_NAME%" /TR "\"%PIPELINE_BAT%\"" /ST 04:00 /RL HIGHEST /F
if errorlevel 1 (
    echo.
    echo Task creation failed - see the schtasks error above. Try re-running
    echo this script as Administrator ^(right-click setup-scheduler.bat -^>
    echo "Run as administrator"^), or use option [3] to adjust the command
    echo by hand.
) else (
    echo.
    echo Done. Manage it later with:
    echo   schtasks /QUERY /TN "%TASK_NAME%" /V
    echo   schtasks /RUN /TN "%TASK_NAME%"
    echo   schtasks /END /TN "%TASK_NAME%"
    echo   schtasks /DELETE /TN "%TASK_NAME%" /F
)
goto :END

:SHOW_ONLY
echo.
echo Run this yourself (adjust /ST "HH:MM" for a different time, or /SC
echo for a different frequency -- DAILY / HOURLY / WEEKLY):
echo.
echo   schtasks /CREATE /SC DAILY /TN "%TASK_NAME%" /TR "\"%PIPELINE_BAT%\"" /ST 04:00 /RL HIGHEST /F
echo.
echo See README.md's "Scheduling" section, or docs\windows-setup.md in a
echo developer checkout, for other frequencies and the full macOS-launchd
echo to Windows-Task-Scheduler mapping.
goto :END

:OPEN_GUI
echo.
echo Opening Task Scheduler. Create a new task with:
echo   Action:          Start a program
echo   Program/script:  %PIPELINE_BAT%
echo   Start in:        %PKG_DIR%
start "" taskschd.msc
goto :END

:CANCEL
echo.
echo Cancelled - no changes made.
goto :END

:END
echo.
pause
popd
exit /b 0
