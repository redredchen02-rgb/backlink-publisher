# Git
.git/
.gitattributes
.gitignore
.gitlab-ci.yml
.github/
bp-*/

# Python cache & virtualenv
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.venv/
.venv*/
.Python
env/
venv/

# Build artifacts
build/
dist/
*.whl
*.tar.gz
*.so

# Test & coverage
tests/
.benchmarks/
.hypothesis/
.pytest_cache/
.coverage*
coverage*.json
.cov-baseline.json
htmlcov/

# Type checking & linting
.mypy_cache/
.ruff_cache/
.import_linter_cache/

# Docs & plans (not needed at runtime)
docs/

# Markdown (keep README + CHANGELOG)
*.md
!README.md
!README.zh.md
!CHANGELOG.md

# Scripts (not needed at runtime)
scripts/*.sh
scripts/*.py
scripts/*.plist
scripts/telegraph_spike/
scripts/velog_spike/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Local dev & agent artifacts
.agents/
.claude/
.ai-memory/
.context/
.omo/
.gstack/
.spectral.yaml
.pre-commit-config.yaml
dev/
logs/
instance/

# Databases & runtime data
*.db
*.sqlite
*.sqlite3
*.log

# Frontend build (built fresh in Docker Node stage)
frontend/node_modules/
frontend/dist/
webui_app/spa_dist/
*.tsbuildinfo
*.snap

# Spike artifacts
*.spike/
spike_*

# Config (only keep template)
!config.example.toml
*.local.toml
*_credentials_dump.json
*_cookies_*.txt

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Coverage reports
.coverage*
coverage*.json
