@echo off
REM launch-cli.bat — Backlink Publisher portable-package CLI shell launcher.
REM
REM Source-controlled copy for scripts/launch-cli.bat in the built package
REM (Plan 2026-07-07-006 Unit 2). This file uses ONLY relative paths
REM (%~dp0-derived) and environment-variable substitution, so no build-time
REM templating is needed -- Unit 3's package assembly step copies it as-is
REM into the output package's scripts/ directory.
REM
REM chcp 65001 guards against the non-UTF-8-console encoding crash fixed in
REM docs/plans/2026-07-03-001-fix-windows-webui-encoding-crash-plan.md.
chcp 65001 >nul

REM This file lives at <pkg_dir>\scripts\launch-cli.bat, so the package root
REM is one level up. pushd is used deliberately instead of CD's /D switch:
REM CD /D cannot make a UNC/network-share path the current directory, but
REM pushd maps it to a temporary drive letter, so this still works when the
REM package is unzipped onto e.g. \\server\share\backlink-publisher\.
set "PKG_DIR=%~dp0.."
pushd "%PKG_DIR%" || (
    echo ERROR: could not change to the package directory "%PKG_DIR%".
    pause
    exit /b 1
)
set "PKG_DIR=%CD%"

if not exist "%PKG_DIR%\python-embed\python.exe" (
    echo ERROR: %PKG_DIR%\python-embed\python.exe was not found.
    echo This package looks incomplete or corrupted -- please re-download
    echo or re-extract the zip and try again.
    echo.
    pause
    popd
    exit /b 1
)

REM webui_store / webui_app live under app\, not in python-embed's
REM site-packages -- some CLI commands (e.g. dispatch-backlinks) import
REM webui_store at module load time, so every shim under cli-shims\ needs
REM the same PYTHONPATH the WebUI launcher sets (see the plan's Key
REM Technical Decisions).
set "PYTHONPATH=%PKG_DIR%\app"

REM Prepend cli-shims\ to PATH for this session only, so typing a command
REM name (bp, plan-backlinks, publish-backlinks, ...) runs the matching
REM <name>.bat shim without needing the full path.
set "PATH=%PKG_DIR%\scripts\cli-shims;%PATH%"

echo Backlink Publisher CLI shell
echo.
echo All commands from pyproject.toml's [project.scripts] are on PATH for
echo this window only. Examples:
echo.
echo   bp                        (lists every command, grouped by purpose)
echo   plan-backlinks --help
echo   publish-backlinks --help
echo.
echo Type "exit" to close this window.
echo.

cmd /k
set "EXITCODE=%ERRORLEVEL%"

popd
exit /b %EXITCODE%
