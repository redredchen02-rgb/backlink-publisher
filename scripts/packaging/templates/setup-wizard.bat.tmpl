@echo off
REM setup-wizard.bat - platform overview + pointer to the WebUI Settings page.
REM
REM Source-controlled copy for scripts/setup-wizard.bat in the built package
REM (Plan 2026-07-07-006 Unit 5). This file uses ONLY relative paths
REM (%~dp0-derived), so no build-time templating is needed -- the build
REM script copies it as-is into the output package's scripts/ directory.
REM
REM Deliberately NOT a config-file-writing wizard: entering credentials (API
REM keys, OAuth client secrets, browser logins) is already fully handled by
REM the WebUI's own Settings page (see ONBOARDING.md's platform walkthrough
REM for the complete step-by-step per platform). This script's only job is
REM to give a non-technical user a quick, guided difficulty/requirements
REM overview of the 5 supported platforms before they open the WebUI, so
REM they can decide where to start without reading all of ONBOARDING.md
REM first. Building a real credential-writing wizard was judged out of
REM scope for this unit -- see the plan's Unit 5 report for the reasoning.
REM
REM chcp 65001 guards against the non-UTF-8-console encoding crash fixed in
REM docs/plans/2026-07-03-001-fix-windows-webui-encoding-crash-plan.md.
chcp 65001 >nul

REM This file lives at <pkg_dir>\scripts\setup-wizard.bat, so the package
REM root is one level up. pushd (not CD /D) so this still works when the
REM package is unzipped onto a UNC / network-share path.
set "PKG_DIR=%~dp0.."
pushd "%PKG_DIR%" || (
    echo ERROR: could not change to the package directory "%PKG_DIR%".
    pause
    exit /b 1
)
set "PKG_DIR=%CD%"

echo ========================================================================
echo  Backlink Publisher - First-time Setup Wizard
echo ========================================================================
echo.
echo This wizard does NOT collect or save any credentials itself. All actual
echo account / API-key / OAuth setup happens on the WebUI's own Settings
echo page (see ONBOARDING.md's platform walkthrough for full step-by-step
echo detail). This is just a quick overview so you can pick where to start.
echo.
echo   Platform     Difficulty   What it needs
echo   -----------  -----------  ---------------------------------------------
echo   Telegraph    Easiest      Nothing - auto-created on first publish
echo   dev.to       Easy         API key from dev.to - Settings - Extensions
echo   Blogger      Medium       Google Cloud OAuth client id / client secret
echo   Medium       Medium       Browser login (run install-playwright.bat first)
echo   Velog        Medium       Browser login (run install-playwright.bat first)
echo.
echo Recommendation: start with Telegraph to confirm everything works end to
echo end, then add other platforms as you actually need them.
echo.
REM set /p (not `choice`) deliberately -- `choice.exe` is unreliable once
REM `chcp 65001` is active (confirmed during Unit 5 testing: it can fail to
REM read a selection at all and print "the file is either empty or does not
REM contain the valid choices"), while `set /p` reads a plain line of text
REM and has no such codepage sensitivity.
set "LAUNCH_NOW="
set /p "LAUNCH_NOW=Launch the WebUI now to open Settings and enter credentials? (Y/N): "
if /I not "%LAUNCH_NOW%"=="Y" goto :SKIP_LAUNCH

echo.
echo Launching the WebUI...
popd
call "%~dp0launch-webui.bat"
exit /b %ERRORLEVEL%

:SKIP_LAUNCH
echo.
echo OK - run scripts\launch-webui.bat whenever you are ready, then open the
echo Settings page to enter credentials for the platform(s) you chose above.
popd
exit /b 0
